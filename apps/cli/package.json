{
  "name": "@sentinel/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sentinel": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:prod": "NODE_ENV=production node esbuild.config.mjs",
    "typecheck": "tsc --noEmit --pretty"
  },
  "dependencies": {
    "@sentinel/core": "workspace:*",
    "@sentinel/providers": "workspace:*",
    "@sentinel/server": "workspace:*",
    "@sentinel/sdk": "workspace:*",
    "@sentinel/shared": "workspace:*",
    "@sentinel/tools": "workspace:*",
    "@sentinel/tui": "workspace:*",
    "commander": "^15.0.0",
    "ink": "^7.0.0",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "typescript": "^5.7.0"
  }
}
